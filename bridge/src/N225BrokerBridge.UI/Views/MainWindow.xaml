<ui:FluentWindow
    x:Class="N225BrokerBridge.UI.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:N225BrokerBridge.UI.ViewModels"
    xmlns:srv="clr-namespace:N225BrokerBridge.UI.Services"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    Title="N225 Broker Bridge"
    Width="1280" Height="820"
    MinWidth="1024" MinHeight="600"
    WindowStyle="None"
    ResizeMode="CanResize"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterScreen">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="48" ResizeBorderThickness="4" CornerRadius="0" GlassFrameThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Wpf.Ui の ControlsDictionary が DataGrid / ColumnHeader / Cell / Row に
             暗黙テーマを適用してきて白線などが出てしまうため、空の TargetType-only Style で
             リセット。各 DataGrid 側で明示的に ColumnHeaderStyle / CellStyle / RowStyle を
             指定しているのでデザインは維持される。 -->
        <Style TargetType="DataGrid"/>
        <Style TargetType="DataGridColumnHeader"/>
        <Style TargetType="DataGridCell"/>
        <Style TargetType="DataGridRow"/>
        <Style TargetType="DataGridColumnHeadersPresenter"/>
        <Style TargetType="DataGridRowsPresenter"/>
        <Style TargetType="DataGridCellsPresenter"/>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Opacity" Value="0.85"/>
        </Style>
        <Style x:Key="StatusKeyStyle" TargetType="TextBlock">
            <Setter Property="Opacity" Value="0.65"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>
        <Style x:Key="PriceValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>
        <Style x:Key="PriceLabelStyle" TargetType="TextBlock">
            <Setter Property="Opacity" Value="0.65"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <!-- DataGrid カラムヘッダー (1px 縦区切り線 + 透明 Thumb で列幅リサイズ可、文字中央寄せ) -->
        <Style x:Key="GridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#2A3340"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="SeparatorVisibility" Value="Collapsed"/>
            <Setter Property="SeparatorBrush" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    TextElement.Foreground="{TemplateBinding Foreground}"
                                    TextElement.FontWeight="{TemplateBinding FontWeight}"
                                    TextElement.FontSize="{TemplateBinding FontSize}"
                                    SnapsToDevicePixels="True"/>
                            </Border>
                            <!-- 右端の最細 1px 縦区切り線 (本体 GridLines と同色)。
                                 IsHitTestVisible=False で Thumb のドラッグを邪魔しない。 -->
                            <Border Width="1" HorizontalAlignment="Right"
                                    Background="#33FFFFFF"
                                    SnapsToDevicePixels="True"
                                    IsHitTestVisible="False"/>
                            <!-- 列幅リサイズ用 Thumb (PART_RightHeaderGripper)。
                                 Wpf.Ui のテーマが Thumb に暗黙適用する装飾 (白線の正体) を
                                 確実に殺すため Style={x:Null} + 空 Template で自前定義。
                                 ヒット幅 6px / 境界線を跨いで -3px〜+3px、SizeWE カーソル。 -->
                            <Thumb x:Name="PART_RightHeaderGripper"
                                   Style="{x:Null}"
                                   HorizontalAlignment="Right"
                                   Width="6"
                                   Margin="0,0,-3,0"
                                   Cursor="SizeWE">
                                <Thumb.Template>
                                    <ControlTemplate TargetType="Thumb">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 選択行を強調する DataGridRow スタイル (建玉・注文 両方で使う) -->
        <Style x:Key="SelectableRowStyle" TargetType="DataGridRow">
            <!-- WPF UI / Mica テーマのデフォルト行パディングを切り詰めて密度高めに表示 -->
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <!-- Wpf.Ui 暗黙テーマが行外側 Border に下辺 1px を仕込んで GridLines と二重になる
                 (横線重複の真因) のを防ぐため、既定状態で必ず 0 / Transparent を明示。
                 行罫線は DataGrid.HorizontalGridLinesBrush (プロパティ側) の 1 本だけに集約。 -->
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Style.Resources>
                <!-- 非アクティブ選択時 (もう片方の DataGrid にフォーカス移動時) も
                     アクティブ時と同じ青ハイライトを維持し、行が白く見える現象を防ぐ -->
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#2D7CC0"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White"/>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <!-- アクセントブルー、文字白で明確にフォーカス -->
                    <Setter Property="Background" Value="#2D7CC0"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="#5AA0E0"/>
                    <Setter Property="BorderThickness" Value="3,0,0,0"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A3A5C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid セル: 罫線は DataGrid 自身の GridLinesVisibility="All" に完全に任せる (重なり回避)。
             空 Style リセットの影響で文字色がデフォルト (黒) になっていたため、明示的に白指定。 -->
        <Style x:Key="CompactCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <!-- BorderBrush / BorderThickness の TemplateBinding は意図的に削除。
                             Wpf.Ui 暗黙テーマがセル側に下辺 1px を設定しても、Template が拾わない
                             ようにすることで、横線が二重に出るのを構造的に防ぐ。
                             罫線は完全に DataGrid.HorizontalGridLinesBrush (プロパティ) に集約。 -->
                        <Border Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              SnapsToDevicePixels="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 数値列セル用: 右寄せ + 桁揃え monospace (価格・建値・損益・数量・足など全数値列で使用) -->
        <Style x:Key="RightAlignCellStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>

        <!-- 文字列セル用: 左寄せ (銘柄・戦略名・ID・時刻文字列・ラベルなど全テキスト列で使用) -->
        <Style x:Key="LeftAlignCellStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <!-- 中央寄せ (現在は未使用。後方互換用に保持) -->
        <Style x:Key="CenterAlignCellStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <!-- ログ ListBox の 1 行スタイル: デフォルトパディングを削って行間を詰める -->
        <Style x:Key="CompactLogItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="2,0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="MinHeight" Value="16"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>

        <!-- 建玉一覧の銘柄グルーピングは一旦無効化 (GroupStyle カスタムテンプレートが
             カラムヘッダーの幅同期を壊す問題のため)。グループ化は将来必要に応じて再実装 -->
        <!--
        <CollectionViewSource x:Key="GroupedPositions" Source="{Binding Positions}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="SymbolName"/>
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>
        -->

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Menu -->
            <RowDefinition Height="Auto"/>   <!-- Status bar -->
            <RowDefinition Height="*"/>      <!-- Main content -->
            <RowDefinition Height="5"/>      <!-- GridSplitter -->
            <RowDefinition x:Name="LogRow" Height="280" MinHeight="120"/>   <!-- Log -->
        </Grid.RowDefinitions>

        <!-- ===== Custom title bar (VS 2022 風: Menu + タイトル + システムボタン を 1 行に統合) ===== -->
        <Grid Grid.Row="0" Background="#2A3340" Height="48"
              MouseLeftButtonDown="OnTitleBarMouseDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>   <!-- Menu -->
                <ColumnDefinition Width="*"/>      <!-- spacer (drag area) -->
                <ColumnDefinition Width="Auto"/>   <!-- タイトル -->
                <ColumnDefinition Width="Auto"/>   <!-- システムボタン -->
            </Grid.ColumnDefinitions>

            <!-- 左: Menu -->
            <Menu Grid.Column="0" Background="Transparent" Padding="0"
                  VerticalAlignment="Center" Foreground="White"
                  shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <MenuItem Header="ファイル(_F)">
                    <MenuItem Header="設定(_S)..." Click="OnSettingsMenuClick"/>
                    <Separator/>
                    <MenuItem Header="終了(_X)" Click="OnExitMenuClick"/>
                </MenuItem>
                <MenuItem Header="戦略(_T)">
                    <MenuItem Header="戦略管理(_M)..." Click="OnStrategyManagerMenuClick"/>
                </MenuItem>
                <MenuItem Header="表示(_V)">
                    <MenuItem Header="ログをクリア"/>
                    <Separator/>
                    <MenuItem Header="列幅を初期値に戻す(_W)" Click="OnResetColumnWidthsMenuClick"/>
                </MenuItem>
                <MenuItem Header="ヘルプ(_H)">
                    <MenuItem Header="バージョン情報" Click="OnAboutMenuClick"/>
                </MenuItem>
            </Menu>

            <!-- 中央: タイトル文字 (VS 2022 のプロジェクト名の位置) -->
            <TextBlock Grid.Column="2" Text="N225 Broker Bridge"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"
                       Foreground="White"
                       FontFamily="Cascadia Code"
                       FontWeight="SemiBold"
                       FontSize="13"
                       Opacity="0.85"/>

            <!-- 右: 最小化 / 最大化 / 閉じる -->
            <StackPanel Grid.Column="3" Orientation="Horizontal"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <StackPanel.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Width" Value="46"/>
                        <Setter Property="Height" Value="48"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                        <Setter Property="FontSize" Value="10"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#4A5568"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </StackPanel.Resources>
                <Button Content="&#xE921;" Click="OnMinimizeClick" ToolTip="最小化"/>
                <Button x:Name="MaxRestoreButton" Content="&#xE922;" Click="OnMaximizeRestoreClick" ToolTip="最大化/元に戻す"/>
                <Button Content="&#xE8BB;" Click="OnCloseClick" ToolTip="閉じる">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Width" Value="46"/>
                            <Setter Property="Height" Value="32"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                            <Setter Property="FontSize" Value="10"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#E81123"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ===== Status bar ===== -->
        <Border Grid.Row="1" Padding="8,4" Background="{DynamicResource ControlFillColorSecondaryBrush}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="ブローカー:" Style="{StaticResource StatusKeyStyle}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding BrokerStatus}" VerticalAlignment="Center" Margin="0,0,24,0" FontWeight="SemiBold"/>

                <TextBlock Text="Webhook:" Style="{StaticResource StatusKeyStyle}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding WebhookStatus}" VerticalAlignment="Center" Margin="0,0,24,0" FontWeight="SemiBold"/>

                <TextBlock Text="状態:" Style="{StaticResource StatusKeyStyle}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StateMessage}"
                            VerticalAlignment="Center" Margin="0,0,24,0"
                            FontWeight="Bold"
                            Foreground="#5BB964"
                            FontSize="14"/>

                <Border Width="1" Background="{DynamicResource ControlElevationBorderBrush}" Margin="8,2"/>

                <ui:ToggleSwitch IsChecked="{Binding IsAutoTradeEnabled, Mode=TwoWay}"
                                  Content="自動売買"
                                  VerticalAlignment="Center"
                                  Margin="16,0,0,0"/>

                <ui:Button Content="状態更新"
                            Command="{Binding RefreshStatusCommand}"
                            Appearance="Secondary"
                            Margin="16,0,0,0"
                            VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ===== Main content (left: manual order / right: data grids) ===== -->
        <Grid Grid.Row="2" Margin="4,4,4,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftPanelColumn" Width="340" MinWidth="280"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="500"/>
            </Grid.ColumnDefinitions>

            <!-- ========== Left: Manual order panel ========== -->
            <!-- ScrollViewer: ウィンドウを縦に縮めても末尾のアクションボタン (買/売/返済/キャンセル) が
                 見切れないように、Border 内全体をスクロール可能にする。横スクロールは無効
                 (横幅は LeftPanelColumn の MinWidth=280 で常に十分確保される)。 -->
            <Border Grid.Column="0"
                    Padding="8"
                    BorderThickness="0"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    CornerRadius="6"
                    Background="Transparent">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="手動発注" Style="{StaticResource SectionHeaderStyle}" FontSize="14" Margin="0,0,0,4"/>

                        <!-- 発注銘柄 (手動発注用、上部選択と独立) -->
                        <TextBlock Text="銘柄" Margin="0,2,0,2" Opacity="0.7"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding AvailableInstruments}"
                                      SelectedItem="{Binding ManualOrderInstrument, Mode=TwoWay}"
                                      DisplayMemberPath="DisplayName"
                                      HorizontalAlignment="Stretch"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding ManualOrderInstrument.ContractMonth}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="{Binding ManualOrderInstrument.ResolvedSymbolCode, StringFormat='銘柄コード: {0}'}"
                                    FontSize="11" Opacity="0.6" Margin="0,2,0,0"/>

                        <!-- 注文タイプ -->
                        <TextBlock Text="注文タイプ" Margin="0,6,0,2" Opacity="0.7"/>
                        <StackPanel Orientation="Horizontal">
                            <StackPanel.Resources>
                                <!-- FontSize を上げると ● (Wpf.Ui の RadioButton 内部 Ellipse) も
                                     比例して大きくなる。Margin で間隔も広げる -->
                                <Style TargetType="RadioButton">
                                    <Setter Property="Margin" Value="0,0,12,0"/>
                                    <Setter Property="Padding" Value="6,0,0,0"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Style>
                            </StackPanel.Resources>
                            <RadioButton Content="対当"  IsChecked="{Binding OrderType, Converter={StaticResource OrderTypeChoiceConv}, ConverterParameter=BestMarket}"/>
                            <RadioButton Content="成行"  IsChecked="{Binding OrderType, Converter={StaticResource OrderTypeChoiceConv}, ConverterParameter=Market}"/>
                            <RadioButton Content="指値"  IsChecked="{Binding OrderType, Converter={StaticResource OrderTypeChoiceConv}, ConverterParameter=Limit}"/>
                            <RadioButton Content="逆指"  IsChecked="{Binding OrderType, Converter={StaticResource OrderTypeChoiceConv}, ConverterParameter=Stop}"/>
                        </StackPanel>

                        <!-- 時間条件 (TIF) — 注文タイプ直下に配置、注文タイプ変更で選択肢が自動切替 -->
                        <TextBlock Text="時間条件 (TIF)" Margin="0,6,0,2" Opacity="0.7"/>
                        <ComboBox ItemsSource="{Binding AvailableTimeInForces}"
                                  SelectedItem="{Binding SelectedTimeInForce, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"/>

                        <!-- 数量 -->
                        <TextBlock Text="数量 (枚)" Margin="0,6,0,2" Opacity="0.7"/>
                        <ui:NumberBox Value="{Binding OrderQty, Mode=TwoWay}"
                                       Minimum="1" Maximum="100" SmallChange="1"
                                       HorizontalAlignment="Stretch"/>

                        <!-- 指値価格: 指値選択時のみ編集可能 + 自動 CurrentPrice セット。
                             他の注文タイプ時は 0 にリセットされ、入力不可 (IsReadOnly + Opacity)。 -->
                        <TextBlock Text="指値価格" Margin="0,6,0,2" Opacity="0.7"/>
                        <ui:NumberBox Value="{Binding LimitPrice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                       IsEnabled="{Binding IsLimitPriceEnabled}"
                                       IsReadOnly="{Binding IsLimitPriceReadOnly}"
                                       Opacity="{Binding LimitPriceOpacity}"
                                       Minimum="0" SmallChange="5"
                                       HorizontalAlignment="Stretch"/>

                        <!-- 逆指値価格: 逆指値選択時のみ編集可能。 -->
                        <TextBlock Text="逆指値価格" Margin="0,6,0,2" Opacity="0.7"/>
                        <ui:NumberBox Value="{Binding StopPrice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                       IsEnabled="{Binding IsStopPriceEnabled}"
                                       IsReadOnly="{Binding IsStopPriceReadOnly}"
                                       Opacity="{Binding StopPriceOpacity}"
                                       Minimum="0" SmallChange="5"
                                       HorizontalAlignment="Stretch"/>

                        <!-- アクションボタン -->
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="4"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ui:Button Grid.Row="0" Grid.Column="0"
                                        Content="買 注 文"
                                        Command="{Binding PlaceBuyOrderCommand}"
                                        Appearance="Primary"
                                        HorizontalAlignment="Stretch"
                                        Height="30"/>
                            <ui:Button Grid.Row="0" Grid.Column="2"
                                        Content="売 注 文"
                                        Command="{Binding PlaceSellOrderCommand}"
                                        Appearance="Danger"
                                        HorizontalAlignment="Stretch"
                                        Height="30"/>

                            <ui:Button Grid.Row="2" Grid.Column="0"
                                        Content="返 　 済"
                                        Command="{Binding ExitPositionCommand}"
                                        Appearance="Secondary"
                                        HorizontalAlignment="Stretch"
                                        Height="28"/>
                            <ui:Button Grid.Row="2" Grid.Column="2"
                                        Content="キャンセル"
                                        Command="{Binding CancelOrderCommand}"
                                        Appearance="Secondary"
                                        HorizontalAlignment="Stretch"
                                        Height="28"/>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="Transparent"/>

            <!-- ========== Right: [Price | Strategies] / Positions / Orders ========== -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Price + Strategies (horizontal split) -->
                    <RowDefinition x:Name="PositionsRow" Height="*"/>
                    <!-- Positions -->
                    <RowDefinition Height="5"/>
                    <!-- Splitter -->
                    <RowDefinition x:Name="OrdersRow" Height="*"/>
                    <!-- Orders -->
                </Grid.RowDefinitions>

                <!-- ===== Top row: Price (left, compact) + Strategies (right, wide) ===== -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <!-- Price compact -->
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <!-- Strategies wide -->
                    </Grid.ColumnDefinitions>

                    <!-- Price (compact: 価格 / BID / ASK 縦並び) -->
                    <Border Grid.Column="0" Padding="6,4"
                            BorderThickness="0"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            CornerRadius="6"
                            Background="Transparent">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="現在値" Style="{StaticResource PriceLabelStyle}" FontSize="11"/>
                                <TextBlock Text="{Binding CurrentPrice, StringFormat=N0}"
                                           FontSize="20" FontWeight="Bold" FontFamily="Consolas"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <TextBlock Text="BID" Width="30" Opacity="0.7" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding BidPrice, StringFormat=N0}" FontFamily="Consolas" FontWeight="SemiBold" Foreground="#5BB964" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding BidQty, StringFormat='×{0}'}" Opacity="0.7" FontSize="11" VerticalAlignment="Center" Margin="6,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="ASK" Width="30" Opacity="0.7" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding AskPrice, StringFormat=N0}" FontFamily="Consolas" FontWeight="SemiBold" Foreground="#F26464" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding AskQty, StringFormat='×{0}'}" Opacity="0.7" FontSize="11" VerticalAlignment="Center" Margin="6,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Strategies (wide right) -->
                    <Border Grid.Column="2" Padding="0"
                            BorderThickness="0"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            CornerRadius="6"
                            Background="Transparent">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Padding="8,2"
                                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                    CornerRadius="6,6,0,0">
                                <TextBlock Text="戦略一覧" Style="{StaticResource SectionHeaderStyle}"/>
                            </Border>
                            <DataGrid x:Name="StrategiesGrid" Grid.Row="1" ItemsSource="{Binding Strategies}"
                                      RowStyle="{StaticResource SelectableRowStyle}"
                                      CellStyle="{StaticResource CompactCellStyle}"
                                      AutoGenerateColumns="False" CanUserAddRows="False"
                                      HeadersVisibility="Column"
                                      ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                                      ColumnHeaderHeight="30"
                                      GridLinesVisibility="All"
                                      HorizontalGridLinesBrush="#33FFFFFF"
                                      VerticalGridLinesBrush="#33FFFFFF"
                                  SnapsToDevicePixels="True"
                                  UseLayoutRounding="True"
                                      Background="Transparent" RowBackground="Transparent" BorderThickness="0"
                                      RowHeight="22" MaxHeight="160"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="有効" Binding="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
                                    <DataGridTextColumn Header="戦略名"   Binding="{Binding AlertName}"     Width="140" IsReadOnly="True" ElementStyle="{StaticResource LeftAlignCellStyle}"/>
                                    <DataGridTextColumn Header="Interval" Binding="{Binding Interval, StringFormat='{}{0}m'}" Width="70" IsReadOnly="True" ElementStyle="{StaticResource RightAlignCellStyle}"/>
                                    <DataGridTextColumn Header="受信時刻" Binding="{Binding LastSignalAt}"  Width="80" IsReadOnly="True" ElementStyle="{StaticResource LeftAlignCellStyle}"/>
                                    <DataGridTextColumn Header="種別"     Binding="{Binding LastTradeType}" Width="60" IsReadOnly="True" ElementStyle="{StaticResource LeftAlignCellStyle}"/>
                                    <DataGridTextColumn Header="売買"     Binding="{Binding LastSide}"      Width="50" IsReadOnly="True" ElementStyle="{StaticResource LeftAlignCellStyle}"/>
                                    <DataGridTextColumn Header="価格"     Binding="{Binding LastPrice}"     Width="80" IsReadOnly="True" ElementStyle="{StaticResource RightAlignCellStyle}"/>
                                    <DataGridTextColumn Header="説明"     Binding="{Binding Description}"   Width="*"  IsReadOnly="True" ElementStyle="{StaticResource LeftAlignCellStyle}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Positions -->
                <Border Grid.Row="1" Padding="0" MinHeight="150"
                        BorderThickness="0"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        CornerRadius="6"
                        Background="Transparent">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Padding="8,2"
                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                CornerRadius="6,6,0,0">
                            <TextBlock Text="建玉一覧" Style="{StaticResource SectionHeaderStyle}"/>
                        </Border>
                        <DataGrid x:Name="PositionsGrid" Grid.Row="1" ItemsSource="{Binding Positions}"
                                  SelectedItem="{Binding SelectedPosition, Mode=TwoWay}"
                                  AutoGenerateColumns="False" CanUserAddRows="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  HeadersVisibility="Column"
                                  ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                                  ColumnHeaderHeight="26"
                                  GridLinesVisibility="All"
                                  HorizontalGridLinesBrush="#33FFFFFF"
                                  VerticalGridLinesBrush="#33FFFFFF"
                                  SnapsToDevicePixels="True"
                                  UseLayoutRounding="True"
                                  Background="Transparent" RowBackground="Transparent" BorderThickness="0"
                                  RowHeight="22"
                                  RowStyle="{StaticResource SelectableRowStyle}"
                                  CellStyle="{StaticResource CompactCellStyle}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="銘柄"   Binding="{Binding SymbolName}"   Width="160" ElementStyle="{StaticResource LeftAlignCellStyle}"/>
                                <DataGridTextColumn Header="モード" Binding="{Binding TradeMode}"    Width="60" ElementStyle="{StaticResource LeftAlignCellStyle}"/>
                                <DataGridTextColumn Header="約定日" Binding="{Binding ExecutionDay}" Width="90" ElementStyle="{StaticResource LeftAlignCellStyle}"/>
                                <DataGridTextColumn Header="戦略名" Binding="{Binding Strategy}"     Width="120" ElementStyle="{StaticResource LeftAlignCellStyle}"/>
                                <DataGridTextColumn Header="足"     Binding="{Binding Interval, StringFormat='{}{0}m'}" Width="50" ElementStyle="{StaticResource RightAlignCellStyle}"/>
                                <DataGridTextColumn Header="売買"   Binding="{Binding Side}"         Width="50" ElementStyle="{StaticResource LeftAlignCellStyle}"/>
                                <DataGridTextColumn Header="残数量" Binding="{Binding LeaveQty}"     Width="60" ElementStyle="{StaticResource RightAlignCellStyle}"/>
                                <DataGridTextColumn Header="注文中" Binding="{Binding HoldQty}"      Width="60" ElementStyle="{StaticResource RightAlignCellStyle}"/>
                                <DataGridTextColumn Header="建値"   Binding="{Binding Price, StringFormat=N0}"  Width="80" ElementStyle="{StaticResource RightAlignCellStyle}"/>
                                <DataGridTextColumn Header="損益"   Binding="{Binding Profit, StringFormat=N0}" Width="80" ElementStyle="{StaticResource RightAlignCellStyle}"/>
                                <DataGridTextColumn Header="約定ID" Binding="{Binding ExecutionId}"  Width="160" ElementStyle="{StaticResource LeftAlignCellStyle}"/>
                                <DataGridTextColumn Header="注文ID" Binding="{Binding OrderId}"      Width="*" ElementStyle="{StaticResource LeftAlignCellStyle}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <GridSplitter Grid.Row="2" HorizontalAlignment="Stretch" Background="Transparent"/>

                <!-- Orders -->
                <Border Grid.Row="3" Padding="0" MinHeight="150"
                        BorderThickness="0"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        CornerRadius="6"
                        Background="Transparent"
                        Margin="0,4,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Padding="8,2"
                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                CornerRadius="6,6,0,0">
                            <TextBlock Text="注文一覧" Style="{StaticResource SectionHeaderStyle}"/>
                        </Border>
                        <DataGrid x:Name="OrdersGrid" Grid.Row="1" ItemsSource="{Binding Orders}"
                                  SelectedItem="{Binding SelectedOrder, Mode=TwoWay}"
                                  AutoGenerateColumns="False" CanUserAddRows="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  HeadersVisibility="Column"
                                  ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                                  ColumnHeaderHeight="26"
                                  GridLinesVisibility="All"
                                  HorizontalGridLinesBrush="#33FFFFFF"
                                  VerticalGridLinesBrush="#33FFFFFF"
                                  SnapsToDevicePixels="True"
                                  UseLayoutRounding="True"
                                  Background="Transparent" RowBackground="Transparent" BorderThickness="0"
                                  RowHeight="22"
                                  RowStyle="{StaticResource SelectableRowStyle}"
                                  CellStyle="{StaticResource CompactCellStyle}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="銘柄"     Binding="{Binding SymbolName}" Width="160" ElementStyle="{StaticResource LeftAlignCellStyle}"/>
                                <DataGridTextColumn Header="モード"   Binding="{Binding TradeMode}"  Width="60" ElementStyle="{StaticResource LeftAlignCellStyle}"/>
                                <DataGridTextColumn Header="受信時刻" Binding="{Binding RecvTime}"   Width="100" ElementStyle="{StaticResource LeftAlignCellStyle}"/>
                                <DataGridTextColumn Header="戦略名"   Binding="{Binding Strategy}"   Width="120" ElementStyle="{StaticResource LeftAlignCellStyle}"/>
                                <DataGridTextColumn Header="足"       Binding="{Binding Interval, StringFormat='{}{0}m'}" Width="50" ElementStyle="{StaticResource RightAlignCellStyle}"/>
                                <DataGridTextColumn Header="種別"     Binding="{Binding CashMargin}" Width="60" ElementStyle="{StaticResource LeftAlignCellStyle}"/>
                                <DataGridTextColumn Header="売買"     Binding="{Binding Side}"       Width="50" ElementStyle="{StaticResource LeftAlignCellStyle}"/>
                                <DataGridTextColumn Header="状態"     Binding="{Binding State}"      Width="80" ElementStyle="{StaticResource LeftAlignCellStyle}"/>
                                <DataGridTextColumn Header="注文数量" Binding="{Binding OrderQty}"   Width="70" ElementStyle="{StaticResource RightAlignCellStyle}"/>
                                <DataGridTextColumn Header="約定済"   Binding="{Binding CumQty}"     Width="60" ElementStyle="{StaticResource RightAlignCellStyle}"/>
                                <DataGridTextColumn Header="価格"     Binding="{Binding Price, StringFormat=N0}" Width="80" ElementStyle="{StaticResource RightAlignCellStyle}"/>
                                <DataGridTextColumn Header="注文ID"   Binding="{Binding OrderId}"     Width="180" ElementStyle="{StaticResource LeftAlignCellStyle}"/>
                                <DataGridTextColumn Header="約定ID"   Binding="{Binding ExecutionId}" Width="*" ElementStyle="{StaticResource LeftAlignCellStyle}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ===== Log splitter ===== -->
        <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch" Background="Transparent"/>

        <!-- ===== Log (full width bottom) ===== -->
        <Border Grid.Row="4" Margin="4,2,4,4"
                BorderThickness="0"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                CornerRadius="6"
                Background="Transparent">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Padding="8,2"
                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                        CornerRadius="6,6,0,0">
                    <TextBlock Text="ログ" Style="{StaticResource SectionHeaderStyle}"/>
                </Border>
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding LogEntries}"
                         BorderThickness="0"
                         Background="Transparent"
                         FontFamily="Consolas"
                         FontSize="12"
                         ItemContainerStyle="{StaticResource CompactLogItemStyle}"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type srv:UiLogEntry}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm:ss.fff'}"
                                            Foreground="Gray" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding Level}" Width="42" Opacity="0.85" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding Message}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
