<ui:FluentWindow
    x:Class="N225BrokerBridge.UI.Views.PositionHistoryWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="ポジション履歴"
    Width="1040" Height="660"
    MinWidth="760" MinHeight="420"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterOwner"
    ShowInTaskbar="False"
    ResizeMode="CanResize">

    <Window.Resources>
        <!-- Wpf.Ui の暗黙 DataGrid テーマ (白線等) をリセット -->
        <Style TargetType="DataGrid"/>
        <Style TargetType="DataGridColumnHeader"/>
        <Style TargetType="DataGridCell"/>
        <Style TargetType="DataGridRow"/>
        <Style TargetType="DataGridColumnHeadersPresenter"/>
        <Style TargetType="DataGridRowsPresenter"/>
        <Style TargetType="DataGridCellsPresenter"/>

        <!-- 列ヘッダー: Thumb を入れない (白線バグ回避) -->
        <Style x:Key="HdrStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#2A3340"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="SeparatorVisibility" Value="Collapsed"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <!-- 数値セル (右寄せ + Consolas) -->
        <Style x:Key="NumCell" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <!-- 文字セル (左寄せ) -->
        <Style x:Key="TxtCell" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
        </Style>

        <Style x:Key="FilterLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Opacity" Value="0.7"/>
            <Setter Property="Margin" Value="14,0,4,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- TitleBar -->
            <RowDefinition Height="Auto"/>   <!-- Filters -->
            <RowDefinition Height="*"/>      <!-- DataGrid -->
            <RowDefinition Height="Auto"/>   <!-- Summary -->
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="ポジション履歴 (日経225)"/>

        <!-- フィルタバー -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="16,40,16,8" VerticalAlignment="Center">
            <TextBlock Text="モード" Style="{StaticResource FilterLabel}" Margin="0,0,4,0"/>
            <ComboBox MinWidth="100" ItemsSource="{Binding ModeOptions}"
                      SelectedItem="{Binding SelectedMode, Mode=TwoWay}"/>
            <TextBlock Text="期間" Style="{StaticResource FilterLabel}"/>
            <ComboBox MinWidth="90" ItemsSource="{Binding PeriodOptions}"
                      SelectedItem="{Binding SelectedPeriod, Mode=TwoWay}"/>
            <TextBlock Text="戦略" Style="{StaticResource FilterLabel}"/>
            <ComboBox MinWidth="140" ItemsSource="{Binding StrategyOptions}"
                      SelectedItem="{Binding SelectedStrategy, Mode=TwoWay}"/>
            <ui:Button Content="再読込" Margin="16,0,0,0" Command="{Binding LoadCommand}"/>
        </StackPanel>

        <DataGrid Grid.Row="2" Margin="16,0,16,8"
                  ItemsSource="{Binding Rows}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto"
                  CanUserAddRows="False"
                  ColumnHeaderStyle="{StaticResource HdrStyle}"
                  RowHeaderWidth="0"
                  Background="Transparent"
                  BorderThickness="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="建玉#" Binding="{Binding TradeNo}" Width="56"
                                    ElementStyle="{StaticResource NumCell}"/>
                <DataGridTextColumn Header="戦略" Binding="{Binding Strategy}" Width="120"
                                    ElementStyle="{StaticResource TxtCell}"/>
                <DataGridTextColumn Header="モード" Binding="{Binding Mode}" Width="64"
                                    ElementStyle="{StaticResource TxtCell}"/>
                <DataGridTextColumn Header="銘柄" Binding="{Binding Instrument}" Width="72"
                                    ElementStyle="{StaticResource TxtCell}"/>
                <DataGridTextColumn Header="売買" Binding="{Binding SideText}" Width="64"
                                    ElementStyle="{StaticResource TxtCell}"/>
                <DataGridTextColumn Header="建玉日時" Binding="{Binding OpenedText}" Width="100"
                                    ElementStyle="{StaticResource TxtCell}"/>
                <DataGridTextColumn Header="建値" Binding="{Binding EntryPrice, StringFormat='#,0'}" Width="80"
                                    ElementStyle="{StaticResource NumCell}"/>
                <DataGridTextColumn Header="決済日時" Binding="{Binding ClosedText}" Width="100"
                                    ElementStyle="{StaticResource TxtCell}"/>
                <DataGridTextColumn Header="返済値" Binding="{Binding ExitPrice, StringFormat='#,0'}" Width="80"
                                    ElementStyle="{StaticResource NumCell}"/>
                <DataGridTextColumn Header="枚数" Binding="{Binding Quantity}" Width="56"
                                    ElementStyle="{StaticResource NumCell}"/>
                <DataGridTextColumn Header="実現損益"
                                    Binding="{Binding RealizedPnl, StringFormat='+#,0;-#,0;0'}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource NumCell}">
                            <Setter Property="Foreground" Value="{Binding PnlBrush}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="累積損益"
                                    Binding="{Binding Cumulative, StringFormat='+#,0;-#,0;0'}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource NumCell}">
                            <Setter Property="Foreground" Value="{Binding CumulativeBrush}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- サマリー -->
        <Border Grid.Row="3" Background="#22000000" Padding="16,10" Margin="0">
            <TextBlock Text="{Binding SummaryText}" Foreground="{Binding SummaryBrush}"
                       FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</ui:FluentWindow>
